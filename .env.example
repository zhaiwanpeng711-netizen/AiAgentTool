# ===================================================
# AI Agent Scheduler - 环境变量配置
# 复制此文件为 .env 并填入实际值
# ===================================================

# LLM 提供商: "anthropic" 或 "openai"
LLM_PROVIDER=anthropic

# Anthropic API Key (用于 Claude Code + NLP 解析)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API Key (用于 Codex + NLP 解析备选)
OPENAI_API_KEY=your_openai_api_key_here

# NLP 解析使用的模型
LLM_MODEL=claude-3-5-sonnet-20241022

# 默认工作目录 (Agent 执行任务的目录)
WORKSPACE_DIR=/Users/yourname/workspace

# Cursor 应用名称 (macOS 上通常是 "Cursor")
CURSOR_APP_NAME=Cursor

# CLI 工具路径 (如果不在 PATH 中则填写完整路径)
CLAUDE_CLI_PATH=claude
CODEX_CLI_PATH=codex

# 后端服务配置
HOST=0.0.0.0
PORT=8000

# 每个 Agent 类型最大并行任务数
MAX_PARALLEL_TASKS=5
